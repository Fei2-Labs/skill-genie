# Skills manifest — all sources declared here
# Run `setup.sh` to sync everything to ~/.agents/skills/

# Local skills: all dirs with SKILL.md in this repo are auto-included.

# Third-party skills
remote:
  - repo: mattpocock/skills
    path: skills
    pick:
      - personal/edit-article
      - personal/obsidian-vault
      - misc/git-guardrails-claude-code
      - misc/migrate-to-shoehorn
      - misc/scaffold-exercises
      - misc/setup-pre-commit
      - engineering/diagnose
      - engineering/tdd
      - engineering/zoom-out
      - productivity/grill-me

  - repo: warpdotdev/oz-skills
    path: .agents/skills
    pick:
      - analysis-artifacts
      - ci-fix
      - create-pull-request
      - dbt-model-index
      - docs-update
      - github-bug-report-triage
      - github-issue-dedupe
      - scheduler
      - seo-aeo-audit
      - slack-qa-investigate
      - terraform-style-check
      - web-accessibility-audit
      - web-performance-audit

  - repo: nextlevelbuilder/ui-ux-pro-max-skill
    path: .claude/skills
    pick:
      - ui-ux-pro-max

# Optional: only installed if the tool is detected on this machine
optional:
  - tool: trellis
    source: npm:@mindfoldhq/trellis/dist/templates/codex/skills
    pick:
      - start
      - brainstorm
      - check
      - check-cross-layer
      - update-spec
      - before-dev
      - break-loop
      - finish-work

# Bundled skills (installed via registry, managed by .bundled_manifest)
# These are auto-installed and not tracked in this manifest.
# To reset: setup.sh --full will clear and reinstall from this file only.

                "mode": "fill"
              }
            },
            {
              "type": "frame",
              "id": "jKKfY",
              "name": "sec2header10",
              "width": "fill_container",
              "gap": 12,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "thEXk",
                  "name": "sec2num",
                  "fill": "#F472B6",
                  "content": "02",
                  "fontFamily": "Syne",
                  "fontSize": 32,
                  "fontWeight": "800"
                },
                {
                  "type": "text",
                  "id": "FOJt6",
                  "name": "sec2title",
                  "fill": "#FAFAFA",
                  "content": "沉浸式体验的崛起",
                  "lineHeight": 1.3,
                  "fontFamily": "Syne",
                  "fontSize": 20,
                  "fontWeight": "700"
                }
              ]
            },
            {
              "type": "text",
              "id": "CYf0G",
              "name": "body10b",
              "fill": "#D4D4D8",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "虚拟现实、增强现实和混合现实技术正在彻底改变我们体验艺术的方式。观众不再是被动的旁观者，而是成为作品的一部分。TeamLab的数字艺术展览吸引了全球数百万访客，证明了沉浸式艺术的巨大潜力。",
              "lineHeight": 1.8,
              "fontFamily": "Manrope",
              "fontSize": 15,
              "fontWeight": "normal"
            },

              ]
            },
            {
              "type": "rectangle",
              "id": "XD0TT",
              "name": "divider5L",
              "fill": "#E4E4E7",
              "width": "fill_container",
              "height": 1
            },
            {
              "type": "text",
              "id": "TuNVC",
              "name": "intro5L",
              "fill": "#3F3F46",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "在快节奏的城市生活中，我们常常忘记了停下脚步的意义。慢生活并非逃离现实，而是学会在喧嚣中为自己创造一片宁静的空间。",
              "lineHeight": 1.8,
              "fontFamily": "Raleway",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "NFFEJ",
              "name": "h2a5L",
              "fill": "#18181B",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "一、晨间仪式的力量",
              "lineHeight": 1.5,
              "fontFamily": "Lora",
              "fontSize": 20,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "tCVro",
              "name": "bodyA5L",
              "fill": "#3F3F46",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "每天清晨，在城市苏醒之前给自己留出半小时。泡一杯茶，坐在窗前看天色渐亮。这种简单的仪式感，能让整个一天都变得从容。不必追求完美的早起时间，重要的是找到属于自己的节奏。当你学会用一杯茶的时间与自己对话，内心的宁静便会自然而来。",
              "lineHeight": 1.8,
              "fontFamily": "Raleway",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "ijbjD",
              "name": "pullQuote5L",
              "width": "fill_container",
              "fill": "#FDF2F8",
              "cornerRadius": 20,
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "#EC489930"
              },
              "layout": "vertical",
              "gap": 8,
              "padding": [
                20,
                24
              ],
              "children": [
                {
                  "type": "text",
                  "id": "nUnOO",
                  "name": "quoteIcon5L",
                  "fill": "#EC4899",
                  "content": "\"",
                  "lineHeight": 0.6,
                  "fontFamily": "Lora",
                  "fontSize": 48,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "GzLMC",
                  "name": "quoteTxt5L",
                  "fill": "#18181B",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "生活的品质不在于拥有多少，而在于你能感受多少。",
                  "lineHeight": 1.7,
                  "fontFamily": "Lora",
                  "fontSize": 16,
                  "fontWeight": "500",
                  "fontStyle": "italic"
                }
              ]
            },
            {
              "type": "frame",
              "id": "6XIqA",
              "name": "articleImg5L",
              "metadata": {
                "type": "unsplash",
                "username": "silverkblack",
                "link": "https://unsplash.com/@silverkblack",
                "author": "Vitaly Gariev"
              },
              "clip": true,
              "width": "fill_container",
              "height": 200,
              "fill": {
                "type": "image",
                "enabled": true,
                "url": "https://images.unsplash.com/photo-1758272423676-21a8b4c5f0f7?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzI1ODAwNTB8&ixlib=rb-4.1.0&q=80&w=1080",
                "mode": "fill"
              },
              "cornerRadius": 16
            },
            {
              "type": "text",
              "id": "ExAWN",
              "name": "h2b5L",
              "fill": "#18181B",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "二、城市中的自然角落",
              "lineHeight": 1.5,
              "fontFamily": "Lora",
              "fontSize": 20,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "ZVl94",
              "name": "bodyB5L",
              "fill": "#3F3F46",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "即使身处繁华都市，自然从未远离。阳台上的几盆绿植、窗台上的一瓶鲜花、周末公园里的林间漫步——这些微小的自然接触，能有效降低焦虑感，恢复内心的平衡。研究表明，每天接触自然 20 分钟就能显著改善心理健康。",
              "lineHeight": 1.8,
              "fontFamily": "Raleway",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "PbSog",
              "name": "tipBox5L",

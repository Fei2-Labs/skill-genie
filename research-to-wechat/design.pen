            },
            {
              "type": "rectangle",
              "id": "Ns2Zj",
              "name": "divider5D",
              "fill": "#2C2520",
              "width": "fill_container",
              "height": 1
            },
            {
              "type": "text",
              "id": "lKq2f",
              "name": "intro5D",
              "fill": "#A8A29E",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "在快节奏的城市生活中，我们常常忘记了停下脚步的意义。慢生活并非逃离现实，而是学会在喧嚣中为自己创造一片宁静的空间。",
              "lineHeight": 1.8,
              "fontFamily": "Raleway",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "iT1Dt",
              "name": "h2a5D",
              "fill": "#FAF5F0",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "一、晨间仪式的力量",
              "lineHeight": 1.5,
              "fontFamily": "Lora",
              "fontSize": 20,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "gasqL",
              "name": "bodyA5D",
              "fill": "#A8A29E",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "每天清晨，在城市苏醒之前给自己留出半小时。泡一杯茶，坐在窗前看天色渐亮。这种简单的仪式感，能让整个一天都变得从容。不必追求完美的早起时间，重要的是找到属于自己的节奏。当你学会用一杯茶的时间与自己对话，内心的宁静便会自然而来。",
              "lineHeight": 1.8,
              "fontFamily": "Raleway",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "juq1E",
              "name": "pullQuote5D",
              "width": "fill_container",
              "fill": "#231D1A",
              "cornerRadius": 20,
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "#F472B630"
              },
              "layout": "vertical",
              "gap": 8,
              "padding": [
                20,
                24
              ],
              "children": [
                {
                  "type": "text",
                  "id": "mESEa",
                  "name": "qIcon5D",
                  "fill": "#F472B6",
                  "content": "\"",
                  "lineHeight": 0.6,
                  "fontFamily": "Lora",
                  "fontSize": 48,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "o1D0X",
                  "name": "qTxt5D",
                  "fill": "#FAF5F0",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "生活的品质不在于拥有多少，而在于你能感受多少。",
                  "lineHeight": 1.7,
                  "fontFamily": "Lora",
                  "fontSize": 16,
                  "fontWeight": "500",
                  "fontStyle": "italic"
                }
              ]
            },
            {
              "type": "frame",
              "id": "5HanF",
              "name": "articleImg5D",
              "metadata": {
                "type": "unsplash",
                "username": "dvhoang2106",
                "link": "https://unsplash.com/@dvhoang2106",
                "author": "Đào Việt Hoàng"
              },
              "clip": true,
              "width": "fill_container",
              "height": 200,
              "fill": {
                "type": "image",
                "enabled": true,
                "url": "https://images.unsplash.com/photo-1768051424283-94ad8114dbd7?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzI1ODAxNDB8&ixlib=rb-4.1.0&q=80&w=1080",
                "mode": "fill"
              },
              "cornerRadius": 16
            },
            {
              "type": "text",
              "id": "rw0gs",
              "name": "h2b5D",
              "fill": "#FAF5F0",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "二、城市中的自然角落",
              "lineHeight": 1.5,
              "fontFamily": "Lora",
              "fontSize": 20,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "lAfN1",
              "name": "bodyB5D",
              "fill": "#A8A29E",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "即使身处繁华都市，自然从未远离。阳台上的几盆绿植、窗台上的一瓶鲜花、周末公园里的林间漫步——这些微小的自然接触，能有效降低焦虑感，恢复内心的平衡。研究表明，每天接触自然 20 分钟就能显著改善心理健康。",
              "lineHeight": 1.8,
              "fontFamily": "Raleway",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "svKWA",
              "name": "tipBox5D",
              "width": "fill_container",
              "fill": "#261E18",
              "cornerRadius": 20,

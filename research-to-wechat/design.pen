            },
            {
              "type": "text",
              "id": "4eguZ",
              "name": "h2c4L",
              "fill": "#1E293B",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "三、开发者的新角色",
              "lineHeight": 1.4,
              "fontFamily": "Space Grotesk",
              "fontSize": 20,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "rC6AL",
              "name": "bodyC4L",
              "fill": "#334155",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "在 AI 自主编程时代，开发者将从代码编写者转变为系统架构师和 AI 协调者。核心竞争力不再是编写代码的速度，而是问题抽象能力、系统设计思维和对 AI 工具的深度理解。掌握 Prompt Engineering 和 Agent 工作流设计，将成为新时代开发者的必备技能。",
              "lineHeight": 1.8,
              "fontFamily": "DM Sans",
              "fontSize": 15,
              "fontWeight": "normal"
            },

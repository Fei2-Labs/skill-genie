                  "fontFamily": "Raleway",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "text",
              "id": "Su0BM",
              "name": "h2c5L",
              "fill": "#18181B",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "三、数字断联的勇气",
              "lineHeight": 1.5,
              "fontFamily": "Lora",
              "fontSize": 20,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "TlGrG",
              "name": "bodyC5L",
              "fill": "#3F3F46",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "每周给自己安排一段「无屏幕时间」。放下手机，关闭电脑，让思绪自由流淌。你会发现，当数字噪音消失后，创造力和灵感反而会悄然降临。慢生活的本质，是重新找回对时间的掌控感，让每一刻都被真实地体验和感受。",
              "lineHeight": 1.8,
              "fontFamily": "Raleway",
              "fontSize": 15,
              "fontWeight": "normal"
            },

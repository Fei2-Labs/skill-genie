                      "name": "codeLine2",
                      "fill": "#93C5FD",
                      "content": "    def plan(self, task):",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 12,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "T2Tw4",
                      "name": "codeLine3",
                      "fill": "#F8FAFC",
                      "content": "        steps = self.analyze(task)",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 12,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "kO35e",

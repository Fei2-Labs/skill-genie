                "mode": "fill"
              }
            },
            {
              "type": "frame",
              "id": "A0cM6",
              "name": "sec2header10",
              "width": "fill_container",
              "gap": 12,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "oTxnq",
                  "name": "sec2num",
                  "fill": "#EC4899",
                  "content": "02",
                  "fontFamily": "Syne",
                  "fontSize": 32,
                  "fontWeight": "800"
                },
                {
                  "type": "text",
                  "id": "QNaId",
                  "name": "sec2title",
                  "fill": "#18181B",
                  "content": "沉浸式体验的崛起",
                  "lineHeight": 1.3,
                  "fontFamily": "Syne",
                  "fontSize": 20,
                  "fontWeight": "700"
                }
              ]
            },
            {
              "type": "text",
              "id": "MwKIT",
              "name": "body10b",
              "fill": "#3F3F46",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "虚拟现实、增强现实和混合现实技术正在彻底改变我们体验艺术的方式。观众不再是被动的旁观者，而是成为作品的一部分。TeamLab的数字艺术展览吸引了全球数百万访客，证明了沉浸式艺术的巨大潜力。",
              "lineHeight": 1.8,
              "fontFamily": "Manrope",
              "fontSize": 15,
              "fontWeight": "normal"
            },

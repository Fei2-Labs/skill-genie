                  "fill": "#D4A017",
                  "width": 40,
                  "height": 2
                },
                {
                  "type": "text",
                  "id": "wXuAv",
                  "name": "h2text6b",
                  "fill": "#FAFAF9",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "材质与色彩的东方叙事",
                  "lineHeight": 1.4,
                  "fontFamily": "Cormorant",
                  "fontSize": 22,
                  "fontWeight": "700"
                }
              ]
            },
            {
              "type": "text",
              "id": "CAv3E",
              "name": "body6b",
              "fill": "#A8A29E",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "竹、木、石、纸——这些天然材质在东方设计中承载着深厚的文化记忆。当代设计师正在重新审视这些传统材料，将其与现代工艺结合，创造出兼具美感与功能的产品。\n\n色彩上，东方美学偏好含蓄内敛的调性：墨黑、象牙白、青瓷绿、赤金，每一种色彩都蕴含着深远的文化寓意。",
              "lineHeight": 1.8,
              "fontFamily": "Montserrat",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "m7KYH",
              "name": "tipBox6",
              "width": "fill_container",
              "fill": "#292524",
              "cornerRadius": 4,
              "stroke": {
                "thickness": 1,
                "fill": "#D4A017"
              },
              "layout": "vertical",
              "gap": 12,
              "padding": 20,
              "children": [
                {
                  "type": "text",
                  "id": "HrJUQ",
                  "name": "tipTitle6",
                  "fill": "#CA8A04",
                  "content": "设计要点",
                  "fontFamily": "Cormorant",
                  "fontSize": 16,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "qNYDW",
                  "name": "tipItem6a",
                  "fill": "#A8A29E",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "• 以少胜多，追求意境的传达而非元素的堆砌",
                  "lineHeight": 1.7,
                  "fontFamily": "Montserrat",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "w8hi6",
                  "name": "tipItem6b",
                  "fill": "#A8A29E",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "• 注重自然材质的运用，强调触感与温度",
                  "lineHeight": 1.7,
                  "fontFamily": "Montserrat",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "8ogjg",
                  "name": "tipItem6c",
                  "fill": "#A8A29E",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "• 色彩取法自然，追求和谐统一的视觉体验",
                  "lineHeight": 1.7,
                  "fontFamily": "Montserrat",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "n6yLy",
              "name": "h2wrap6c",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "rectangle",
                  "id": "RVjKB",
                  "name": "goldLine6c",
                  "fill": "#D4A017",
                  "width": 40,
                  "height": 2
                },
                {
                  "type": "text",
                  "id": "3opWK",
                  "name": "h2text6c",
                  "fill": "#FAFAF9",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "传统与未来的对话",
                  "lineHeight": 1.4,
                  "fontFamily": "Cormorant",
                  "fontSize": 22,
                  "fontWeight": "700"
                }
              ]
            },
            {
              "type": "text",
              "id": "bkJfj",
              "name": "body6c",
              "fill": "#A8A29E",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "东方美学的魅力在于它的包容性与适应力。它不排斥现代技术，而是以一种优雅的方式将其融入传统美学框架。从故宫博物院的数字化展览到国潮品牌的兴起，我们看到传统美学正在以全新的面貌走向世界舞台。",
              "lineHeight": 1.8,
              "fontFamily": "Montserrat",
              "fontSize": 15,
              "fontWeight": "normal"
            },

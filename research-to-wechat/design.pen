                  "height": 1
                }
              ]
            },
            {
              "type": "text",
              "id": "CcgVf",
              "name": "intro6",
              "fill": "#44403C",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "在全球化浪潮中，东方美学以其独特的韵味与意境，正在深刻影响着现代设计的走向。从建筑到产品，从平面到交互，传统东方元素与当代设计语言的碰撞，催生出令人惊叹的创新作品。",
              "lineHeight": 1.8,
              "fontFamily": "Montserrat",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "ipUql",
              "name": "h2wrap6a",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "rectangle",
                  "id": "um61w",
                  "name": "goldLine6a",
                  "fill": "#CA8A04",
                  "width": 40,
                  "height": 2
                },
                {
                  "type": "text",
                  "id": "Usw2t",
                  "name": "h2text6a",
                  "fill": "#0C0A09",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "留白之道：空间的智慧",
                  "lineHeight": 1.4,
                  "fontFamily": "Cormorant",
                  "fontSize": 22,
                  "fontWeight": "700"
                }
              ]
            },
            {
              "type": "text",
              "id": "P3jkc",
              "name": "body6a",
              "fill": "#44403C",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "中国传统绘画中的留白手法，在现代设计中找到了全新的表达方式。留白不仅仅是空白，更是一种对空间的深层理解——它赋予观者以想象的余地，让设计在克制中彰显力量。\n\n日本建筑大师安藤忠雄的作品完美诠释了这一理念。他用清水混凝土构建的空间，通过光影的自然流动，创造出令人沉思的静谧氛围。",
              "lineHeight": 1.8,
              "fontFamily": "Montserrat",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "00puc",
              "name": "quote6",
              "width": "fill_container",
              "fill": "#F5F0E8",
              "gap": 16,
              "padding": [
                20,
                24
              ],
              "children": [
                {
                  "type": "rectangle",
                  "id": "2HYeq",
                  "name": "quoteBorder6",
                  "fill": "#CA8A04",
                  "width": 3,
                  "height": "fill_container"
                },
                {
                  "type": "frame",
                  "id": "9j7LS",
                  "name": "quoteInner6",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 8,
                  "children": [
                    {
                      "type": "text",
                      "id": "PZFdz",
                      "name": "quoteText6",
                      "fill": "#0C0A09",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "“设计的最高境界，不是加法而是减法，不是填满而是留白。”",
                      "lineHeight": 1.7,
                      "fontFamily": "Cormorant",
                      "fontSize": 16,
                      "fontWeight": "600",
                      "fontStyle": "italic"
                    },
                    {
                      "type": "text",
                      "id": "rwhr3",
                      "name": "quoteAuthor6",
                      "fill": "#A8A29E",
                      "content": "— 原研哉",
                      "fontFamily": "Montserrat",
                      "fontSize": 13,
                      "fontWeight": "500"
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "Jep5e",
              "name": "artImg6",
              "metadata": {
                "type": "unsplash",
                "username": "audumbar999",
                "link": "https://unsplash.com/@audumbar999",

                    },
                    {
                      "type": "text",
                      "id": "BfgM8",
                      "name": "authorDate",
                      "fill": "#94A3B8",
                      "content": "2024.03.15 · 阅读 8 分钟",
                      "fontFamily": "Open Sans",
                      "fontSize": 12,
                      "fontWeight": "normal"
                    }
                  ]

                  "name": "quoteText8",
                  "fill": "#E0E7FF",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "💡 “创造力就是把两个不相干的事情联系在一起的能力。”",
                  "lineHeight": 1.6,
                  "fontFamily": "Fredoka",

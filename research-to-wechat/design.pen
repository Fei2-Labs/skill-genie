            },
            {
              "type": "text",
              "id": "4q4Dw",
              "name": "h2bD",
              "fill": "#F8FAFC",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "二、自主编程的技术突破",
              "lineHeight": 1.4,
              "fontFamily": "Space Grotesk",
              "fontSize": 20,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "1WVsD",
              "name": "bodyBD",
              "fill": "#94A3B8",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "多模态理解、长上下文窗口和 Agent 架构的成熟，使 AI 具备了自主完成复杂任务的能力。它可以阅读文档、分析代码库、执行测试并自主修复问题。这种从「辅助」到「自主」的跨越，标志着软件工程范式的根本性转变。",
              "lineHeight": 1.8,
              "fontFamily": "DM Sans",
              "fontSize": 15,
              "fontWeight": "normal"
            },

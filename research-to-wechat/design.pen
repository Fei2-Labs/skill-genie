                      "content": "慢生活小贴士",
                      "fontFamily": "Lora",
                      "fontSize": 15,
                      "fontWeight": "600"
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "Rr4PH",
                  "name": "tipTx5D",
                  "fill": "#D6D3D1",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "尝试「5-4-3-2-1」感官练习：看到 5 样东西、触碰 4 样东西、听到 3 种声音、闻到 2 种气味、品尝 1 种味道。这个简单的方法能帮助你快速回到当下。",
                  "lineHeight": 1.7,
                  "fontFamily": "Raleway",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "text",
              "id": "NUrHK",
              "name": "h2c5D",
              "fill": "#FAF5F0",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "三、数字断联的勇气",
              "lineHeight": 1.5,
              "fontFamily": "Lora",
              "fontSize": 20,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "45OZ7",
              "name": "bodyC5D",
              "fill": "#A8A29E",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "每周给自己安排一段「无屏幕时间」。放下手机，关闭电脑，让思绪自由流淌。你会发现，当数字噪音消失后，创造力和灵感反而会悄然降临。慢生活的本质，是重新找回对时间的掌控感，让每一刻都被真实地体验和感受。",
              "lineHeight": 1.8,
              "fontFamily": "Raleway",
              "fontSize": 15,
              "fontWeight": "normal"
            },

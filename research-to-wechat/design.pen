              "cornerRadius": 4
            },
            {
              "type": "frame",
              "id": "UIujN",
              "name": "h2wrap6b",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "rectangle",
                  "id": "Df8mN",

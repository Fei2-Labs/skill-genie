            },
            {
              "type": "frame",
              "id": "CPwtd",
              "name": "sec3header10",
              "width": "fill_container",
              "gap": 12,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "EzTVu",
                  "name": "sec3num",
                  "fill": "#EC4899",
                  "content": "03",
                  "fontFamily": "Syne",
                  "fontSize": 32,
                  "fontWeight": "800"
                },
                {
                  "type": "text",
                  "id": "a0cMf",
                  "name": "sec3title",
                  "fill": "#18181B",
                  "content": "AI与创作者的共生",
                  "lineHeight": 1.3,
                  "fontFamily": "Syne",
                  "fontSize": 20,
                  "fontWeight": "700"
                }
              ]
            },
            {
              "type": "text",
              "id": "ULdlf",
              "name": "body10c",
              "fill": "#3F3F46",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "人工智能正从工具演变为创作伙伴。DALL-E、Midjourney和Stable Diffusion等生成式AI工具让每个人都能成为视觉创作者。这引发了关于创造力本质、版权归属和艺术价值的深层讨论。",
              "lineHeight": 1.8,
              "fontFamily": "Manrope",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "NoEIH",
              "name": "sec4header10",
              "width": "fill_container",
              "gap": 12,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "bBHsR",
                  "name": "sec4num",
                  "fill": "#EC4899",
                  "content": "04",
                  "fontFamily": "Syne",
                  "fontSize": 32,
                  "fontWeight": "800"
                },
                {
                  "type": "text",
                  "id": "Sb0xW",
                  "name": "sec4title",
                  "fill": "#18181B",
                  "content": "未来展望：融合的边界",
                  "lineHeight": 1.3,
                  "fontFamily": "Syne",
                  "fontSize": 20,
                  "fontWeight": "700"
                }
              ]
            },
            {
              "type": "text",
              "id": "5TJ8W",
              "name": "body10d",
              "fill": "#3F3F46",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "艺术与技术的融合不会停止。随着脑机接口、量子计算和空间计算技术的发展，未来的艺术创作将超越我们当前的想象。关键在于，技术应该服务于人类的创造力，而非取代它。",
              "lineHeight": 1.8,
              "fontFamily": "Manrope",
              "fontSize": 15,
              "fontWeight": "normal"
            },

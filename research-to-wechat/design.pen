              "fill": {
                "type": "image",
                "enabled": true,
                "url": "https://images.unsplash.com/photo-1554415824-7cc47f524e53?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzI5ODE2ODN8&ixlib=rb-4.1.0&q=80&w=1080",
                "mode": "fill"

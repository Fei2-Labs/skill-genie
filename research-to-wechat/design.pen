                  "offset": {
                    "x": 4,
                    "y": 4
                  }
                },
                {
                  "type": "shadow",
                  "shadowType": "outer",
                  "color": "#FB923C",
                  "offset": {
                    "x": -2,
                    "y": -2
                  }
                }
              ],
              "layout": "vertical",
              "gap": 8,
              "padding": 20,
              "children": [

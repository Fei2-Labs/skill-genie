              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "🌈 让创意成为习惯",
              "lineHeight": 1.4,
              "fontFamily": "Fredoka",
              "fontSize": 21,
              "fontWeight": "700"
            },
            {

  skillgenie sync --dry-run

tip: for a full environment refresh (rules + skills + agents) run ./setup.sh
     from the repo root instead of 'skillgenie update --all'.
        """,
    )

    sub = parser.add_subparsers(dest="command", required=True)

    # list
    sub.add_parser(
        "list",
        help="List every skill in ./skills/ with its description.",

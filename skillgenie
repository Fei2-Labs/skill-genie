                    "printing each skill name and the first line of its description.",
    )

    # read
    p_read = sub.add_parser(
        "read",
        help="Print a skill's full SKILL.md content.",
        description="Print the full SKILL.md for <skill>. Looks in ./skills/<skill>/ "
                    "first, then falls back to ~/.agents/skills/<skill>/. Useful for "
                    "pasting a skill's instructions into an agent chat.",
    )
    p_read.add_argument("skill", help="Skill name (run 'skillgenie list' to see options)")

    # status
    sub.add_parser(
        "status",
        help="Show which runtime has which skill installed.",
        description="Print an install matrix: one row per skill in ./skills/, one "
                    "column per runtime target, showing whether each runtime's skill "
                    "directory contains that skill.",
    )

    # validate
    p_validate = sub.add_parser(
        "validate",
        help="Check SKILL.md frontmatter for cross-agent compatibility.",
        description="Validate SKILL.md frontmatter against the AgentSkills/OpenClaw/"
                    "Hermes/OpenCode/Kiro/Devin compatibility rules: required fields "
                    "(name, description, metadata), name format, description length, "
                    "single-line metadata JSON, etc. Run before committing skill changes.",
    )
    p_validate.add_argument("skill", nargs="?", help="Skill name (omit to validate all)")
    p_validate.add_argument("--all", action="store_true", help="Validate all skills (default when no skill is given)")

    # shared flags for install / update
    def add_target_flags(p):
        p.add_argument("skill", nargs="?", help="Skill name (omit and use --all for every skill)")
        p.add_argument("--all",      action="store_true", help="Apply to all skills in ./skills/")
        g = p.add_mutually_exclusive_group()
        g.add_argument("--global", "-g",   action="store_true", dest="global",   help="All supported runtimes (overrides auto-detect)")
        g.add_argument("--agents",          action="store_true", dest="agents",   help="AgentSkills root (~/.agents/skills/)")
        g.add_argument("--claude", "-cc",  action="store_true", dest="claude",   help="Claude Code only (~/.claude/skills/)")
        g.add_argument("--openclaw", "-oc",action="store_true", dest="openclaw", help="OpenClaw only (~/.openclaw/skills/) [copy]")
        g.add_argument("--hermes",          action="store_true", dest="hermes",   help="Hermes only (~/.hermes/skills/) [copy]")
        g.add_argument("--kiro",            action="store_true", dest="kiro",     help="Kiro only (~/.kiro/skills/)")
        g.add_argument("--codex",           action="store_true", dest="codex",    help="Codex only (~/.codex/skills/)")
        g.add_argument("--opencode",        action="store_true", dest="opencode", help="OpenCode only (~/.config/opencode/skills/)")
        g.add_argument("--devin",           action="store_true", dest="devin",    help="Devin CLI + Desktop, formerly Windsurf (~/.config/devin/skills/) [copy]")
        g.add_argument("--antigravity",     action="store_true", dest="antigravity", help="Gemini Antigravity only (~/.gemini/antigravity/skills/)")
        g.add_argument("--cursor",          action="store_true", dest="cursor",   help="Cursor only (~/.cursor/skills/)")
        g.add_argument("--copilot",         action="store_true", dest="copilot",  help="GitHub Copilot only (~/.github/skills/)")
        g.add_argument("--copilot-cli",     action="store_true", dest="copilot_cli", help="GitHub Copilot CLI/app only (~/.copilot/skills/)")
        g.add_argument("--windsurf",        action="store_true", dest="windsurf", help="Windsurf only (~/.codeium/windsurf/skills/)")
        g.add_argument("--windsurf-next",   action="store_true", dest="windsurf_next", help="Windsurf Next only (~/.codeium/windsurf-next/skills/)")
        p.add_argument("--dry-run", action="store_true", help="Show what would be installed/updated without writing anything")

    p_install = sub.add_parser(
        "install",
        help="Install skill(s) into one or more runtime directories.",
        description="Copy or symlink a skill from ./skills/<name>/ into the chosen "
                    "runtime skill directory (e.g. ~/.claude/skills/). With no target "
                    "flag, auto-detects every runtime present on this machine. "
                    "Symlink targets track the repo live; copy targets (OpenClaw, "
                    "Hermes, Devin) snapshot the skill at install time.",
    )
    add_target_flags(p_install)

    p_update = sub.add_parser(
        "update",
        help="Update (re-install) skill(s) — refresh after editing or pulling.",
        description="Re-install a skill into one or more runtime directories. "
                    "Functionally identical to 'install', but signals that you are "
                    "refreshing an already-installed skill with new content from "
                    "./skills/<name>/. Use after editing a SKILL.md or pulling "
                    "upstream changes. Run 'skillgenie validate' first.",
    )
    add_target_flags(p_update)

    # sync
    p_sync = sub.add_parser(
        "sync",
        help="Pull remote skill repos from skills.yaml and install picked skills.",
        description="Read the 'remote:' section of skills.yaml, clone (first run) or "
                    "pull (subsequent runs) each declared repo into "
                    "~/.local/share/skill-genie-remotes/, and install the picked skills "
                    "into ~/.agents/skills/. Entries with a 'local:' path use your "
                    "existing checkout directly (no clone, no pull). With --global, also "
                    "link/copy each synced skill into every detected native runtime "
                    "directory. Use after editing skills.yaml or to refresh third-party "
                    "skills. Requires pyyaml.",
    )
    p_sync.add_argument("--global", "-g", action="store_true", dest="global",
                        help="Also install synced skills into every detected native runtime dir")
    p_sync.add_argument("--copy", action="store_true",
                        help="Copy skills instead of symlinking (snapshots, like setup.sh --copy)")
    p_sync.add_argument("--clean", action="store_true",
                        help="Wipe ~/.cache/skill-genie-remotes/ first (force re-clone)")
    p_sync.add_argument("--dry-run", action="store_true",
                        help="Show what would be cloned/pulled/installed without writing anything")

    args = parser.parse_args()

    dispatch = {
        "list":    cmd_list,
        "read":    cmd_read,
        "validate": cmd_validate,
        "status":  cmd_status,
        "install": cmd_install,
        "update":  cmd_update,
        "sync":    cmd_sync,
    }
    dispatch[args.command](args)


if __name__ == "__main__":
    main()
